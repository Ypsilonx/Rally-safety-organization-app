# Rally Safety App Configuration

# App settings
APP_NAME=Rally Safety App
APP_VERSION=0.1.0
DEBUG=True

# Server settings
HOST=0.0.0.0
PORT=8000
RELOAD=True

# WebSocket settings
WS_MAX_CONNECTIONS=200
WS_HEARTBEAT_INTERVAL=30

# Auth settings (CHANGE IN PRODUCTION!)
SESSION_SECRET=change-this-in-production-use-random-32-chars-minimum
SESSION_EXPIRE_MINUTES=480

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
